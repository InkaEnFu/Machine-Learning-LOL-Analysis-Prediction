  <diagram id="activity_predict" name="Activity: Prediction Flow">
    <mxGraphModel dx="1000" dy="1800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Start -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="358" y="30" width="30" height="30" as="geometry" />
        </mxCell>
        <!-- Step 1: User input -->
        <mxCell id="a1" value="User enters Riot ID + Tag + Region" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="258" y="100" width="230" height="50" as="geometry" />
        </mxCell>
        <!-- Decision: valid input? -->
        <mxCell id="d1" value="Valid input?" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="298" y="190" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="err1" value="HTTP 422&#xa;Unprocessable Entity" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="520" y="195" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="end_err1" value="" style="ellipse;aspect=fixed;fillColor=#000000;strokeColor=#000000;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="585" y="270" width="30" height="30" as="geometry" />
        </mxCell>
        <!-- Step 2: Fetch account -->
        <mxCell id="a2" value="GET account by Riot ID&#xa;(Riot Account v1)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="258" y="290" width="230" height="50" as="geometry" />
        </mxCell>
        <!-- Decision: account found? -->
        <mxCell id="d2" value="Account found?" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="298" y="380" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="err2" value="HTTP 404 Player not found&#xa;HTTP 403 API key invalid" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="520" y="385" width="180" height="50" as="geometry" />
        </mxCell>
        <!-- Step 3: Fetch match IDs -->
        <mxCell id="a3" value="GET ranked match IDs&#xa;(Match v5, queue=420, count=20)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="258" y="480" width="230" height="50" as="geometry" />
        </mxCell>
        <!-- Decision: any matches? -->
        <mxCell id="d3" value="Any matches?" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="298" y="570" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="err3" value="HTTP 404&#xa;No ranked matches found" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="520" y="575" width="180" height="50" as="geometry" />
        </mxCell>
        <!-- Step 4: Loop match details -->
        <mxCell id="a4" value="Loop: GET match details&#xa;Extract participant data&#xa;(skip non-ranked queues)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="258" y="670" width="230" height="65" as="geometry" />
        </mxCell>
        <!-- Decision: enough matches? -->
        <mxCell id="d4" value="≥ 3 matches?" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="298" y="775" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="err4" value="HTTP 404&#xa;Not enough ranked matches" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="520" y="780" width="180" height="50" as="geometry" />
        </mxCell>
        <!-- Step 5: Feature engineering -->
        <mxCell id="a5" value="aggregate_player_games()&#xa;mean / std / median of 10 features&#xa;winrate, unique_roles, champions" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="248" y="875" width="250" height="65" as="geometry" />
        </mxCell>
        <!-- Step 6: ML Inference -->
        <mxCell id="a6" value="ML Inference&#xa;StandardScaler.transform()&#xa;model.predict() → rank&#xa;model.predict_proba() → confidence" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="248" y="980" width="250" height="75" as="geometry" />
        </mxCell>
        <!-- Step 7: Analytics -->
        <mxCell id="a7" value="compute_comparison()&#xa;z-score + percentile per metric&#xa;compute_all_ranks_distance()" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="248" y="1095" width="250" height="65" as="geometry" />
        </mxCell>
        <!-- Step 8: Real rank (optional) -->
        <mxCell id="a8" value="GET real rank (League v4)&#xa;[optional, non-blocking]" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="248" y="1200" width="250" height="50" as="geometry" />
        </mxCell>
        <!-- Step 9: Rank progression -->
        <mxCell id="a9" value="compute_rank_progression()&#xa;LP to next tier + estimated games" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="248" y="1290" width="250" height="55" as="geometry" />
        </mxCell>
        <!-- Step 10: Champion recs -->
        <mxCell id="a10" value="recommend_champions()&#xa;cosine_similarity(player_vec, champ_profiles)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="248" y="1385" width="250" height="55" as="geometry" />
        </mxCell>
        <!-- Step 11: Response -->
        <mxCell id="a11" value="Return JSON Response&#xa;(prediction, stats, comparison,&#xa;matches, recommendations, progression)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="248" y="1480" width="250" height="65" as="geometry" />
        </mxCell>
